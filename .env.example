FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=replace_with_secret
FEISHU_CHAT_ID=oc_xxx

LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=sk-xxx
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_FALLBACK_MODEL=deepseek-reasoner

# Optional OpenAI alternative:
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-xxx
# OPENAI_MODEL=gpt-4.1-mini
# OPENAI_FALLBACK_MODEL=gpt-4.1

# Optional generic fallback model. Provider-specific fallback variables above take priority.
# LLM_FALLBACK_MODEL=your_fallback_model

NEWS_LOOKBACK_HOURS=24
MAX_NEWS_ITEMS=35
